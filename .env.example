# Переопределение каталога для кэша HuggingFace. В Docker эта настройка переопределяется на /models.
# Можно не менять, если запуск локальный и вас устраивает расположение кэша по умолчанию (обычно C:\Users\user\.cache\huggingface).
HF_HOME=D:/Projects/RAG/.models

# Qdrant
# Для локального запуска без Docker оставьте localhost.
# В docker-compose переменная QDRANT_HOST переопределяется на qdrant.
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# HTTP API
RAG_API_BIND=0.0.0.0
RAG_API_PORT=8000

# Порты Qdrant по умолчанию доступны только с хоста Docker.
# Для удаленного доступа к Qdrant напрямую поменяйте 127.0.0.1 на 0.0.0.0.
QDRANT_HTTP_BIND=127.0.0.1
QDRANT_GRPC_BIND=127.0.0.1

# Эмбеддинги
EMBEDDING_MODEL=Octen/Octen-Embedding-0.6B
EMBEDDING_DIM=1024

# Генератор
GENERATOR_MODEL=QuantTrio/Qwen3.5-9B-AWQ
GENERATOR_BASE_URL=http://localhost:8001/v1
GENERATOR_API_KEY=local-vllm-key
GENERATOR_TIMEOUT=900

# Необязательно: переопределяет системный промпт.
# Если переменная пустая или отсутствует, используется встроенный промпт по умолчанию.
# SYSTEM_PROMPT="Ты полезный RAG-ассистент. Отвечай только по контексту и на языке вопроса."

# Для запуска на GPU по умолчанию используем float16.
# Если запускаете без GPU, поменяйте на auto или float32.
TORCH_DTYPE=float16

# Максимальное количество токенов в сгенерированном ответе. Увеличение этого значения может привести к более длинным ответам, но также увеличивает время генерации и потребление ресурсов.
MAX_NEW_TOKENS=512
# Параметр, контролирующий разнообразие генерируемого текста. Более высокое значение приводит к более разнообразным ответам, а более низкое - к более консервативным и предсказуемым ответам.
TEMPERATURE=0.2

# Retrieval
TOP_K=5
# Размер контекстного окна в терминах количества предыдущих ходов диалога, которые учитываются при генерации ответа.
CONTEXT_WINDOW_TURNS=3

# Разбиение документов
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# RAGAS оценка
RAGAS_CONFIG_PATH=eval/ragas_config.json
RAGAS_TESTSET_PATH=eval/testset.jsonl
RAGAS_OUTPUT_DIR=eval/results
RAGAS_TIMEOUT=900
RAGAS_LLM_MODEL=QuantTrio/Qwen3.5-9B-AWQ
RAGAS_LLM_BASE_URL=http://localhost:8001/v1
RAGAS_LLM_API_KEY=local-vllm-key
RAGAS_LLM_TEMPERATURE=0.0
RAGAS_LLM_MAX_TOKENS=3072
RAGAS_LLM_TIMEOUT=900
RAGAS_LLM_WAIT_TIMEOUT=600
RAGAS_LLM_WAIT_INTERVAL=5

# Параметры для vLLM
VLLM_BASE_IMAGE=vllm/vllm-openai:nightly
VLLM_PATCHED_IMAGE=local-vllm-qwen35-awq:latest
VLLM_API_BIND=127.0.0.1
VLLM_API_PORT=8001
VLLM_MAX_MODEL_LEN=10240
VLLM_GPU_MEMORY_UTILIZATION=0.6
VLLM_QUANTIZATION=awq
VLLM_KV_CACHE_DTYPE=fp8

# Опционально для аутентификации на HuggingFace и скачивания моделей без лимита по скорости.
# HF_TOKEN=
