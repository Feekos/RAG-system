{
  "testset_path": "eval/testset.jsonl",
  "output_dir": "eval/results",
  "metrics": [
    "faithfulness",
    "answer_relevancy",
    "context_precision",
    "context_recall"
  ],
  "llm": {
    "use_rag_generator": true
  },
  "embeddings": {
    "use_rag_embeddings": true
  },
  "rag": {
    "lazy_generator": true,
    "top_k": 5,
    "index_path": "data/documents",
    "reset_index": false
  },
  "experiments": {
    "top_k": [3, 5],
    "chunk_size": [384, 512],
    "chunk_overlap": [48, 64],
    "embedding_model": ["Octen/Octen-Embedding-0.6B"],
    "embedding_dim": [1024],
    "generator_model": ["QuantTrio/Qwen3.5-9B-AWQ"],
    "max_new_tokens": [384],
    "temperature": [0.0]
  },
  "outputs": {
    "json": true,
    "csv": true,
    "markdown": true
  }
}
